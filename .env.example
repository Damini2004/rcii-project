VITE_API_URL=http://localhost:5000/api
PORT=5000
CLIENT_URL=http://localhost:5173

# Create a root .env file in the project root that contains both frontend and backend env vars.
# Vite only exposes VITE_ prefixed vars to the frontend; backend reads the rest from the same file.

# Frontend Firebase config
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID

# Backend Firebase config
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
FIREBASE_CLIENT_EMAIL=your-service-account-email

# Notes:
# - Do not commit your real .env file to source control.
# - Keep the private key and client email secret in your local root .env file.
# - If you prefer, backend service account credentials can alternatively be stored in FIREBASE_SERVICE_ACCOUNT instead of FIREBASE_CLIENT_EMAIL/FIREBASE_PRIVATE_KEY.
